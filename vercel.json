{
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://api.flow-telligence.com/api/v1/:path*"
    },
    {
      "source": "/health/:path*",
      "destination": "https://api.flow-telligence.com/health/:path*"
    },
    {
      "source": "/((?!\\.well-known|assets|canvaskit|icons|favicon\\.ico|flutter\\.js|flutter_bootstrap\\.js|flutter_service_worker\\.js|main\\.dart\\.js|manifest\\.json|version\\.json).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    }
  ]
}
