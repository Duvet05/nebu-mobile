# Ejemplo de configuracion para builds locales.
# En CI/produccion usa --dart-define y GitHub Variables/Secrets.

# App runtime configuration (client-safe)
ENV=development
API_URL=https://api.flow-telligence.com/api/v1
SERVER_URL=https://api.flow-telligence.com
WS_URL=wss://api.flow-telligence.com/api/v1
LIVEKIT_URL=wss://livekit.flow-telligence.com
ENABLE_DEBUG_LOGS=true
ENABLE_CRASH_REPORTING=false

# Social auth (client-safe IDs, not secrets)
GOOGLE_WEB_CLIENT_ID=874117365573-41585jcimi2t77j0bou38e1la0ke8jk6.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
FACEBOOK_APP_ID=your_facebook_app_id
APPLE_CLIENT_ID=your_apple_client_id

# GitHub Secrets used by release workflows
GOOGLE_SERVICES_JSON_BASE64=base64_android_google_services_json
GOOGLE_SERVICE_INFO_PLIST_BASE64=base64_ios_google_service_info_plist
UPLOAD_KEYSTORE_BASE64=base64_android_upload_keystore
KEYSTORE_PASSWORD=your_android_keystore_password
KEY_PASSWORD=your_android_key_password
KEY_ALIAS=your_android_key_alias
PLAY_SERVICE_ACCOUNT_JSON=base64_google_play_service_account_json

# Backend-only secrets. Do not compile these into the mobile app.
API_KEY=your_backend_api_key_if_needed
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WEBHOOK_SECRET=your_livekit_webhook_secret
MONGODB_URI=your_mongodb_uri
JWT_SECRET=your_jwt_secret
OPENAI_API_KEY=your_openai_api_key
